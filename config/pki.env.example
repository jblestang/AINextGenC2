# Production PKI environment variables (coalition exercise)
#
# Unset MIM_CONFORMANCE_KEYS in production. Set MIM_CONFORMANCE_KEYS=1 for lab/conformance only.

# Comma-separated SPKI PEM files for inbound NMBS verification
MIM_NMB_TRUST=/etc/mim/nmb-trust.pem

# PKCS#8 PEM signing keys (separate NMBS and KAS hierarchies)
MIM_NMB_SIGNING_KEY=/etc/mim/nmb-signing.pk8
MIM_KAS_SIGNING_KEY=/etc/mim/kas-signing.pk8

# Lab / CI conformance mode (uses bundled deterministic RSA fixture)
# MIM_CONFORMANCE_KEYS=1
